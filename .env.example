# Copy this file to .env and fill in your credentials.
# .env is gitignored — never commit real credentials.

# ─── Reddit (required) ───────────────────────────────────────────────────────
# Create a free "script" app at https://www.reddit.com/prefs/apps
REDDIT_CLIENT_ID=your_reddit_client_id_here
REDDIT_CLIENT_SECRET=your_reddit_client_secret_here
REDDIT_USER_AGENT=coloring_book_pipeline/1.0 by your_username

# ─── Twitter / X (optional) ──────────────────────────────────────────────────
# Free tier bearer token from https://developer.twitter.com/
# Leave blank to skip Twitter entirely — pipeline works without it.
TWITTER_BEARER_TOKEN=

# ─── Gumroad publishing (optional) ───────────────────────────────────────────
# Needed only for --publish-previews. Get your token at:
# https://app.gumroad.com/settings/advanced (scroll to "Applications")
GUMROAD_ACCESS_TOKEN=

# ─── Logging ─────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
